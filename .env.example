# Port for the web server to listen on
PORT=3009

# Authentication password for uploads and admin console
PASSWORD=YourSecurePasswordHere

# Maximum storage capacity limit in Gigabytes (GB)
MAX_STORAGE_LIMIT_GB=20

# Telegram Bot Token for notification alerts
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Telegram Chat/Group ID where alerts will be delivered
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID
